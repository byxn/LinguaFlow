{
  "name": "@readmind/extension",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "^0.88.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@readmind/types": "workspace:*"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  },
  "manifest": {
    "manifest_version": 3,
    "name": "ReadMind",
    "version": "0.1.0",
    "description": "AI-powered bilingual reading assistant",
    "permissions": ["activeTab", "storage", "contextMenus"],
    "host_permissions": ["<all_urls>"]
  }
}
