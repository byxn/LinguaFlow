{
  "name": "@readmind/extension",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@readmind/types": "workspace:*",
    "plasmo": "^0.88.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "@types/node": "^20.11.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "3",
    "typescript": "^5.4.0"
  },
  "manifest": {
    "manifest_version": 3,
    "name": "ReadMind",
    "version": "0.1.0",
    "description": "AI 阅读翻译助手 - 沉浸式双语翻译与学习",
    "permissions": [
      "activeTab",
      "storage",
      "contextMenus"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  }
}
